# =============================================================================
# Devcontainer Configuration
# =============================================================================
# Copy this file to .env in the same folder and edit with your details:
#   cp .devcontainer/.env.example .devcontainer/.env
#   nano .devcontainer/.env
# =============================================================================

# Git user name (for commits)
GIT_USER_NAME=your_name_here

# Git user email (for commits)
GIT_USER_EMAIL=your_email_here

# GitHub Personal Access Token (for GitHub CLI and MCP server)
# Create at: https://github.com/settings/tokens
# Required scopes: repo, user:email, workflow
GH_TOKEN=your_github_personal_access_token_here

# Weights & Biases API Key (for pulling runs)
# Create at: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Weights & Biases mode: "online" (default), "offline", or "disabled"
WANDB_MODE=online

# Context7 API Key (for documentation MCP server)
CONTEXT7_API_KEY=your_context7_api_key_here
